clc; clear; close all

g = im2double(imread('cameraman.tif'));

% g_low = 0.3 + 0.4*g; % comprime contraste

g_low = 0.4*g;

g_eq = histeq(g_low);


figure





figure

subplot(2,3,1), imshow(g), title('Original')
subplot(2,3,2), imshow(g_low), title('Baixo contraste')
subplot(2,3,3), imshow(g_eq), title('Equalizada')

subplot(2,3,4), imhist(g)
subplot(2,3,5), imhist(g_low)
subplot(2,3,6), imhist(g_eq)